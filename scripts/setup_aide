#!/bin/bash
set -euo pipefail

source /usr/share/yunohost/helpers

WATCH_DIRS="${1:-/home/yunohost.backup/archives}"
APP_NAME=$YNH_APP_INSTANCE_NAME
AIDE_CONF_DIR="/etc/aide/aide.conf.d"
AIDE_CONF="${AIDE_CONF_DIR}/decoy_watch.conf"
AIDE_DB_DIR="/var/lib/aide"
AIDE_DB_NEW="${AIDE_DB_DIR}/aide.db.new.gz"
AIDE_DB="${AIDE_DB_DIR}/aide.db.gz"

ynh_script_progression --message="Initializing AIDE database..."

mkdir -p "$AIDE_CONF_DIR" "$AIDE_DB_DIR" /var/log/aide

# Write the AIDE include fragment using Debian's conf.d pattern
cat > "$AIDE_CONF" << EOF
# DecoyWatch AIDE Configuration Fragment
# Monitors decoy files for unauthorized access/modification
# Generated by DecoyWatch installer - do not edit manually

# Custom rule: all attributes + sha512
DECOYWATCH = p+i+n+u+g+s+m+c+acl+xattrs+sha512
EOF

# Append a rule per watch directory
IFS=',' read -ra DIRS <<< "$WATCH_DIRS"
for dir in "${DIRS[@]}"; do
    dir="$(echo "$dir" | xargs)"  # trim whitespace
    if [[ -d "$dir" ]]; then
        echo "${dir} DECOYWATCH" >> "$AIDE_CONF"
        ynh_print_info --message="Added AIDE rule for: ${dir}"
    else
        ynh_print_warn --message="Directory does not exist yet, skipping AIDE rule: ${dir}"
    fi
done

chmod 640 "$AIDE_CONF"
if getent group _aide >/dev/null 2>&1; then
    chown root:_aide "$AIDE_CONF" "$AIDE_DB_DIR" /var/log/aide
else
    chown root:root "$AIDE_CONF" "$AIDE_DB_DIR" /var/log/aide
fi
chmod 750 "$AIDE_DB_DIR" /var/log/aide

# FIX: Use aide --init directly instead of aideinit wrapper.
# aideinit exits 18 when aide finds "changes" during a first-run scan,
# which is expected behaviour on a fresh system - not an error.
# aide --init exits 0 on success and only fails on config/permission errors.
ynh_print_info --message="Building initial AIDE database (this may take a moment)..."

if aide --init --config /etc/aide/aide.conf 2>&1 | tee /tmp/aide_init.log; then
    ynh_print_info --message="AIDE database initialized successfully"
else
    AIDE_EXIT=${PIPESTATUS[0]}
    # Exit code 18 = differences found (normal on first run with existing files)
    # Exit codes 1-7 = real errors (config, permission, I/O problems)
    if [[ "$AIDE_EXIT" -le 7 ]]; then
        ynh_die --message="AIDE init failed (exit ${AIDE_EXIT}). Check /tmp/aide_init.log for details."
    fi
    ynh_print_warn --message="AIDE init completed with warnings (exit ${AIDE_EXIT}) - this is normal on first run"
fi

# Move new database to active location
if [[ -f "$AIDE_DB_NEW" ]]; then
    cp "$AIDE_DB_NEW" "$AIDE_DB"
    chmod 640 "$AIDE_DB"
    if getent group _aide >/dev/null 2>&1; then
        chown root:_aide "$AIDE_DB"
    else
        chown root:root "$AIDE_DB"
    fi
    ynh_print_info --message="AIDE database activated at ${AIDE_DB}"
else
    ynh_print_warn --message="AIDE db file not found at ${AIDE_DB_NEW} - may need manual init later"
fi

# Create systemd timer for daily checks
cat > /etc/systemd/system/decoy-aide-check.service << EOF
[Unit]
Description=DecoyWatch AIDE Integrity Check
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/bin/aide --check --config /etc/aide/aide.conf
StandardOutput=journal
StandardError=journal
EOF

cat > /etc/systemd/system/decoy-aide-check.timer << EOF
[Unit]
Description=Daily DecoyWatch AIDE Check
Requires=decoy-aide-check.service

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
EOF

chmod 644 /etc/systemd/system/decoy-aide-check.service /etc/systemd/system/decoy-aide-check.timer
systemctl daemon-reload
systemctl enable decoy-aide-check.timer 2>/dev/null && \
    ynh_print_info --message="AIDE periodic check timer enabled"

ynh_print_info --message="AIDE monitoring configured successfully"
